// Default zellij layout used by `worker create`.
// Left column: terminal (top) + lazygit (bottom). Right column: claude.
layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="https://github.com/ishefi/zellaude/releases/latest/download/zellaude.wasm"
    }
    children
    pane size=2 borderless=true {
      plugin location="zellij:status-bar"
    }
  }
  tab split_direction="vertical" {
    pane split_direction="horizontal" size="50%" {
      pane name="terminal"
      pane name="lazygit" {
        command "lazygit"
      }
    }
    pane name="claude" {
      command "claude"
__WORKER_CLAUDE_ARGS__
    }
  }
}
